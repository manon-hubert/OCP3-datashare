# ================================================================
# DATASHARE - SHARED ENVIRONMENT VARIABLES
# ================================================================
# This file contains shared configuration used by both the backend and e2e tests.
# Copy this file to .env and fill in the values.
#
# IMPORTANT: Never commit the actual .env file to git!
# ================================================================

# ----------------------------------------------------------------
# DATABASE CONNECTION
# ----------------------------------------------------------------
# Full PostgreSQL connection string
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
#
# Default values match docker-compose.yml for local development.
# ----------------------------------------------------------------
DATABASE_URL=postgresql://dbuser:dbpwd@localhost:5432/datashare

# ----------------------------------------------------------------
# DOCKER SETUP
# ----------------------------------------------------------------
# Default values match docker-compose.yml for local development.
# ----------------------------------------------------------------
DB_USER=dbuser
DB_PASSWORD=dbpwd
DB_NAME=datashare
DB_PORT=5432

# ----------------------------------------------------------------
# FRONTEND URL
# ----------------------------------------------------------------
# Base URL where the frontend is running.
# Used by the backend for CORS and by e2e tests to navigate to the app.
# ----------------------------------------------------------------
FRONTEND_URL=http://localhost:5173