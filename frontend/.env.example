# ================================================================
# DATASHARE - FRONTEND ENVIRONMENT VARIABLES
# ================================================================
# Frontend-specific configuration for the React application.
# Copy this file to .env and fill in the values.
#
# IMPORTANT: Never commit the actual .env file to git!
# ================================================================

# ----------------------------------------------------------------
# BACKEND API URL
# ----------------------------------------------------------------
# Base URL where the backend API is running.
# All API requests from the frontend are sent to this URL.
# ----------------------------------------------------------------
VITE_API_URL=http://localhost:3000

# ----------------------------------------------------------------
# FRONTEND DEV SERVER PORT (OPTIONAL)
# ----------------------------------------------------------------
# Port the Vite development server runs on.
# Default: 5173 (Vite's default)
#
# Only needed if you want to run the frontend on a different port.
# Uncomment to override the default.
# ----------------------------------------------------------------
# VITE_PORT=5173