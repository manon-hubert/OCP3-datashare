# ================================================================
# DATASHARE - BACKEND ENVIRONMENT VARIABLES
# ================================================================
# Backend-specific configuration for the NestJS application.
# Copy this file to .env and fill in the values.
#
# IMPORTANT: Never commit the actual .env file to git!
# ================================================================

# ----------------------------------------------------------------
# SERVER CONFIGURATION
# ----------------------------------------------------------------
# Port the NestJS server listens on.
# Default: 3000 (standard for Node.js applications)
# ----------------------------------------------------------------
PORT=3000

# ----------------------------------------------------------------
# AUTHENTICATION
# ----------------------------------------------------------------
# Secret key used to sign and verify JWT tokens.
#
# SECURITY CONSIDERATIONS:
# - Must be at least 32 characters long
# - Must be cryptographically random
#
# You can generate a secure random secret with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# DO NOT use the placeholder below in production!
# ----------------------------------------------------------------
JWT_SECRET=your-secret-key-here-minimum-32-characters-recommended


# ----------------------------------------------------------------
# JWT EXPIRATION
# ----------------------------------------------------------------
# How long JWT tokens remain valid.
# Format: time string (e.g., '15m', '1h', '7d')
# ----------------------------------------------------------------
JWT_EXPIRES_IN=15m


# ----------------------------------------------------------------
# FILE STORAGE
# ----------------------------------------------------------------
# Directory where uploaded files are stored on the local filesystem.
# Path is relative to the backend directory.
# ----------------------------------------------------------------
UPLOAD_PATH=./uploads


# ----------------------------------------------------------------
# FILE SIZE LIMIT
# ----------------------------------------------------------------
# Maximum file size in bytes that can be uploaded.
# Must match VITE_MAX_FILE_SIZE in frontend/.env.
# Default: 1000000000 (1 GB in SI standard)
# ----------------------------------------------------------------
MAX_FILE_SIZE=1000000000